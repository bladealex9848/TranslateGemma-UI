# TranslateGemma-UI Environment Configuration
# Copy this file to .env and modify as needed

# =================================================================
# OLLAMA SERVER CONFIGURATION
# =================================================================

# Ollama server host URL
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Default TranslateGemma model to use
# Options: translategemma:4b, translategemma:12b, translategemma:27b
# Recommended: translategemma:latest (fastest, ~17 t/s on your server)
OLLAMA_MODEL=translategemma:latest

# Request timeout in seconds
OLLAMA_TIMEOUT=60

# =================================================================
# APPLICATION SETTINGS
# =================================================================

# Application port (if running backend)
APP_PORT=3000

# Application host
APP_HOST=0.0.0.0

# Public URL for the application
APP_PUBLIC_URL=https://translate.cedula360.tech

# Enable debug mode (true/false)
DEBUG=false

# =================================================================
# ALIANZA CÉDULA 360 (server-side, NO commitear valores reales)
# =================================================================

# PocketBase URL (server-side proxy / impersonate)
POCKETBASE_URL=http://127.0.0.1:8094

# Superusuario de PocketBase — SOLO en /root/.translate_secrets / .env real
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# API REAL de Cédula 360 (:3081). NUNCA :9091 (stub que responde 200 sin auth)
CEDULA360_API_BASE=http://localhost:3081
# Bypass opcional de rate-limit + recaptcha (header x-internal-cron-token)
CEDULA360_INTERNAL_TOKEN=

# reCAPTCHA v3 (claves de Cédula 360). El secret NO se commitea.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Ldufr4sAAAAAEX6uLIrV3Uk4auM7zksyUvdeA-k
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.3

# =================================================================
# CORS SETTINGS (if running backend)
# =================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =================================================================
# STORAGE
# =================================================================

# History storage path (local)
HISTORY_PATH=./data/history

# Maximum history entries to keep
MAX_HISTORY_ENTRIES=1000
